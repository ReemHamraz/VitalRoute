# Server
PORT=8080
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173

# Firebase (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Google APIs (one key, enable Maps + Directions + Distance Matrix in console)
GOOGLE_MAPS_API_KEY=AIza...

# Gemini
GEMINI_API_KEY=AIza...

# JWT
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# FCM (Firebase Cloud Messaging server key)
FCM_SERVER_KEY=AAAA...
