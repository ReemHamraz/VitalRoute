# Server
PORT=8080
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173

# Firebase Admin (from Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Firebase Client (CRITICAL FOR LOGIN - from Project Settings > General > Web API Key)
FIREBASE_WEB_API_KEY=AIzaSy...

# Google APIs (Maps + Directions + Distance Matrix)
GOOGLE_MAPS_API_KEY=AIzaSy...

# Gemini AI
GEMINI_API_KEY=AIzaSy...

# Security
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
